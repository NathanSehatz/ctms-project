@model CTMS.Models.Concert

<h2>Edit Concert</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>Title</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Location</label>
        <input asp-for="Location" />
    </div>

    <div>
        <label>Date</label>
        <input asp-for="Date" />
    </div>

    <button type="submit">Save</button>
</form>

<a asp-action="Index">Back</a>
@{
    ViewData["Title"] = "Reserve Tickets";
}

<div class="form-page">
    <div class="page-header">
        <h2>Reserve Tickets</h2>
    </div>

    <div class="card p-4">
        <div class="mb-4">
            <p class="mb-2"><strong>Ticket:</strong> @ViewBag.TicketName</p>
            <p class="mb-0"><strong>Available:</strong> @ViewBag.Available</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger mb-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            <input type="hidden" name="ticketTypeId" value="@ViewBag.TicketTypeId" />

            <div class="mb-4">
                <label for="quantity" class="form-label">Quantity</label>
                <input id="quantity" name="quantity" type="number" min="1" class="form-control" required />
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-success">Reserve</button>
                <a asp-controller="Reservation" asp-action="Index" class="btn btn-secondary">Back to Reservations</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
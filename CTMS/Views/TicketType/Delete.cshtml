@model CTMS.Models.TicketType

<h2>Delete Ticket Type</h2>

<p>Are you sure you want to delete this ticket type?</p>

<div class="mb-3">
    <strong>Name:</strong> @Model.Name <br />
    <strong>Price:</strong> @Model.Price <br />
    <strong>Quantity Available:</strong> @Model.QuantityAvailable
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-concertId="@Model.ConcertId" class="btn btn-secondary">Cancel</a>
</form>
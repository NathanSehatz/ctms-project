@model IEnumerable<CTMS.Models.TicketType>

<h2>Ticket Types for @ViewBag.ConcertTitle</h2>

<p>
    <a asp-action="Create" asp-route-concertId="@ViewBag.ConcertId" class="btn btn-primary">Add Ticket Type</a>
    <a asp-controller="Concert" asp-action="Index" class="btn btn-secondary">Back to Concerts</a>
</p>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Price</th>
        <th>Quantity Available</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.QuantityAvailable</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                <a asp-controller="Reservation" asp-action="Create" asp-route-ticketTypeId="@item.Id" class="btn btn-success btn-sm">Reserve</a>
            </td>
        </tr>
    }
    </tbody>
</table>